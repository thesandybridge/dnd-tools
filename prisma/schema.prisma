generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── NextAuth models ──────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  color           String?
  bio             String?
  themeName       String   @default("parchment") @map("theme_name")
  themeMode       String   @default("dark") @map("theme_mode")
  particleEffect  String   @default("auto") @map("particle_effect")
  coronaIntensity Float    @default(0.8) @map("corona_intensity")
  timezone        String   @default("UTC")

  accounts             Account[]
  sessions             Session[]
  guilds               Guild[]       @relation("GuildOwner")
  guildMembers         GuildMember[]
  markers              Marker[]
  characters           Character[]
  joinRequests         JoinRequest[] @relation("JoinRequestUser")
  reviewedJoinRequests JoinRequest[] @relation("JoinRequestReviewer")

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ── App models ───────────────────────────────────────────────────────

model Guild {
  id                Int    @id @default(autoincrement())
  guildId           String @unique @default(uuid()) @map("guild_id")
  name              String
  ownerId           String @map("owner")
  description       String?
  visibility        String   @default("private")
  defaultRoleId     Int?     @map("default_role_id")
  requestExpiryDays Int?     @default(7) @map("request_expiry_days")

  ownerUser    User          @relation("GuildOwner", fields: [ownerId], references: [id])
  members      GuildMember[]
  maps         GuildMap[]
  roles        GuildRole[]
  joinRequests JoinRequest[]

  @@map("guilds")
}

model GuildMember {
  guildId  String   @map("guild_id")
  userId   String   @map("user_id")
  roleId   Int      @map("role_id")
  joinedAt DateTime @default(now()) @map("joined_at")

  guild Guild     @relation(fields: [guildId], references: [guildId], onDelete: Cascade)
  user  User      @relation(fields: [userId], references: [id])
  role  GuildRole @relation(fields: [roleId], references: [id])

  @@id([guildId, userId])
  @@map("guild_members")
}

model GuildRole {
  id              Int      @id @default(autoincrement())
  guildId         String   @map("guild_id")
  name            String
  color           String   @default("#6b7280")
  position        Int
  manageMembers   Boolean  @default(false) @map("manage_members")
  manageMaps      Boolean  @default(false) @map("manage_maps")
  manageMarkers   Boolean  @default(false) @map("manage_markers")
  manageGuild     Boolean  @default(false) @map("manage_guild")
  isSystem        Boolean  @default(false) @map("is_system")
  createdAt       DateTime @default(now()) @map("created_at")

  guild   Guild         @relation(fields: [guildId], references: [guildId], onDelete: Cascade)
  members GuildMember[]

  @@unique([guildId, position])
  @@unique([guildId, name])
  @@map("guild_roles")
}

model GuildMap {
  id               Int      @id @default(autoincrement())
  mapId            String   @unique @default(uuid()) @map("map_id")
  guildId          String   @map("guild_id")
  name             String
  pmtilesUrl       String   @map("pmtiles_url")
  pmtilesApiKey    String?  @map("pmtiles_api_key")
  imageWidth       Int?     @map("image_width")
  imageHeight      Int?     @map("image_height")
  maxZoom          Int      @default(5) @map("max_zoom")
  defaultZoom      Int?     @map("default_zoom")
  defaultCenterLat Float?   @map("default_center_lat")
  defaultCenterLng Float?   @map("default_center_lng")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  visibility String   @default("everyone")

  guild   Guild    @relation(fields: [guildId], references: [guildId], onDelete: Cascade)
  markers Marker[]

  @@index([guildId])
  @@map("guild_maps")
}

model Marker {
  id         Int      @id @default(autoincrement())
  uuid       String   @unique @default(uuid())
  userId     String   @map("user_id")
  guildMapId String   @map("guild_map_id")
  position   Json
  distance   Float?   @default(0)
  prevMarker String?  @map("prev_marker")
  createdAt  DateTime @default(now()) @map("created_at")
  text       String?

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  guildMap GuildMap @relation(fields: [guildMapId], references: [mapId], onDelete: Cascade)

  @@index([guildMapId])
  @@map("markers")
}

model Character {
  id        Int      @id @default(autoincrement())
  userId    String   @map("user_id")
  name      String
  race      String?
  charClass String?  @map("char_class")
  subclass  String?
  level     Int      @default(1)
  backstory String?
  avatarUrl String?  @map("avatar_url")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("characters")
}

model JoinRequest {
  id         Int       @id @default(autoincrement())
  guildId    String    @map("guild_id")
  userId     String    @map("user_id")
  message    String?
  status     String    @default("pending")
  reviewedBy String?   @map("reviewed_by")
  reviewedAt DateTime? @map("reviewed_at")
  expiresAt  DateTime? @map("expires_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  guild    Guild @relation(fields: [guildId], references: [guildId], onDelete: Cascade)
  user     User  @relation("JoinRequestUser", fields: [userId], references: [id], onDelete: Cascade)
  reviewer User? @relation("JoinRequestReviewer", fields: [reviewedBy], references: [id])

  @@index([guildId, status])
  @@map("join_requests")
}
